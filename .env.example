# Local default: file:./dev.db. Production should use a persistent database URL.
APP_URL=http://localhost:3000
DATABASE_URL=file:./dev.db
AUTH_SECRET=replace-with-at-least-32-random-characters
EMAIL_FROM=Safe Nest <hello@safenest.example>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
STORAGE_ENDPOINT=
STORAGE_PROVIDER=local
STORAGE_FORCE_PATH_STYLE=false
STORAGE_REGION=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
FILE_SIGNING_SECRET=replace-with-another-long-random-secret
RATE_LIMIT_PROVIDER=memory
RATE_LIMIT_URL=
RATE_LIMIT_TOKEN=
SENTRY_DSN=
NEXT_PUBLIC_SITE_NAME=Safe Nest Housing & Support
ORGANISATION_TIMEZONE=Europe/London
PRIVATE_STORAGE_PATH=storage/private
MALWARE_SCAN_PROVIDER=disabled
MALWARE_SCAN_URL=
MALWARE_SCAN_TOKEN=
REQUIRE_MALWARE_SCAN=false
RETENTION_REVIEW_SECRET=replace-with-a-long-random-scheduler-secret
# Local development convenience only — never has any effect when NODE_ENV=production.
# Set to true to skip MFA enrollment/verification while testing the CRM locally.
DISABLE_MFA_FOR_DEV=false
